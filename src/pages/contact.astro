<BaseLayout
  title="Contact - Anastasia Bessonova"
  description="Contact Anastasia Bessonova, narrative designer and scriptwriter."
>
  <section class="block reading flow">
    <h1>Contact</h1>

    <p>
      For narrative design work, writing collaborations, or professional inquiries,
      feel free to get in touch.
    </p>

    <p>
      Clear context, scope, and timelines are always appreciated.
    </p>
  </section>

  <section class="section block reading flow">
    <h2>Email</h2>

    <p>
      <strong>
        <a href="mailto:nastasia.bessonova@gmail.com">
          nastasia.bessonova@gmail.com
        </a>
      </strong>
    </p>
  </section>

  <section class="section block reading flow">
    <h2>Professional profiles</h2>

    <ul>
      <li>
        <a
          href="https://www.linkedin.com/in/anastasia-bessonova-1b27a636/"
          target="_blank"
          rel="noreferrer"
        >
          LinkedIn
        </a>
      </li>
      <li>
        <a
          href="https://www.kinopoisk.ru/name/4733697/"
          target="_blank"
          rel="noreferrer"
        >
          Kinopoisk — animation filmography
        </a>
      </li>
    </ul>
  </section>

  <section class="section block reading flow">
    <p class="muted">
      Based in Porto, Portugal. Available for freelance, contract, or studio work.
    </p>
  </section>

  <style>
    .muted {
      color: var(--muted);
    }
  </style>
</BaseLayout>
